# ----------------------------------------------------------------------
# Настройки Apache-хостинга для GLAIRE
# ----------------------------------------------------------------------
# GitHub Pages этот файл не использует, но на REG.RU и похожем Apache-хостинге
# он помогает держать сайт быстрым и безопасным: HTTPS, кеш, сжатие и заголовки.

# Не даём серверу показывать список файлов папки, если случайно нет index.html.
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Если сайт открыли через http://, переводим на https://.
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Если открыли www.glaire.ru, аккуратно переводим на основной домен glaire.ru.
  RewriteCond %{HTTP_HOST} ^www\.glaire\.ru$ [NC]
  RewriteRule ^ https://glaire.ru%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_deflate.c>
  # Сжимаем текстовые файлы: HTML, CSS, JS, XML, JSON и SVG.
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml image/svg+xml
</IfModule>

<IfModule mod_brotli.c>
  # Если на хостинге включён Brotli, он сожмёт текст ещё лучше, чем gzip.
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/xml
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
  AddOutputFilterByType BROTLI_COMPRESS application/xml image/svg+xml
</IfModule>

<IfModule mod_headers.c>
  # Базовые безопасные заголовки, которые не ломают внешний вид и JS сайта.
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(self)"
  Header append Vary "Accept-Encoding"

  # HTML должен обновляться быстро после правок.
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  # Статические ресурсы можно хранить дольше: это помогает PageSpeed и браузерам.
  <FilesMatch "\.(css|js|woff2|png|jpg|jpeg|webp|gif|svg|ico|xml|webmanifest)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
